# Backend Environment Variables
NODE_ENV=development
PORT=3002

# Database Configuration (used by raw pg pool)
DB_HOST=localhost
DB_PORT=5435
DB_NAME=attendance_db
DB_USER=postgres
DB_PASSWORD=change_me

# Prisma Database URL
DATABASE_URL=postgresql://postgres:change_me@localhost:5435/attendance_db

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Email (Admin password reset)
# If not set, reset links are logged to backend console (dev fallback).
SMTP_SERVICE=gmail
SMTP_USER=
SMTP_PASS=
